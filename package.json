{
  "name": "@toyokumo/oxlint-config",
  "version": "0.1.1",
  "description": "oxlint rule set for Toyokumo",
  "keywords": [
    "oxlint"
  ],
  "homepage": "https://github.com/toyokumo/oxlint-config",
  "license": "Apache-2.0",
  "author": "Toyokumo, Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toyokumo/oxlint-config.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "lint": "oxlint",
    "format": "oxfmt --write",
    "test": "node --test 'tests/**/*.test.js'",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1"
}
