{
  "include": ["src/**/*"],
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "types": [],
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "strict": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  }
}
